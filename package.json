{
  "name": "konoha-vivant",
  "version": "0.1.0",
  "description": "Konoha Vivant — bac a sable Naruto (atelier d'animations puis jeu).",
  "main": "main.js",
  "author": "zarentos",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.7.6",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.zarentos.konohavivant",
    "productName": "Konoha Vivant",
    "files": [
      "main.js",
      "preload.js",
      "konoha.config.json",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/@node-llama-cpp/*-cuda*/**",
      "!node_modules/node-llama-cpp/llama/gitRelease.bundle",
      "!node_modules/@node-llama-cpp/*armv7l*/**",
      "!node_modules/**/*.{md,map,ts}",
      "!node_modules/**/{test,tests,__tests__,docs,example,examples}/**"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "artifactName": "KonohaVivant-Setup-${version}.${ext}",
      "files": [
        "!node_modules/@node-llama-cpp/*arm*/**"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "identity": null,
      "category": "public.app-category.games",
      "artifactName": "KonohaVivant-${version}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "files": [
        "!node_modules/@node-llama-cpp/*arm*/**"
      ]
    },
    "asarUnpack": [
      "node_modules/node-llama-cpp/**",
      "node_modules/@node-llama-cpp/**"
    ],
    "npmRebuild": false
  },
  "dependencies": {
    "node-llama-cpp": "^3.19.0"
  }
}
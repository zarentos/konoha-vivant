{
  "name": "konoha-vivant",
  "version": "0.1.0",
  "description": "Konoha Vivant — bac a sable Naruto (atelier d'animations puis jeu).",
  "main": "main.js",
  "author": "zarentos",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.7.6",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.zarentos.konohavivant",
    "productName": "Konoha Vivant",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "directories": { "output": "dist" },
    "win": { "target": "nsis", "artifactName": "KonohaVivant-Setup-${version}.${ext}" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true },
    "mac": { "target": "dmg", "identity": null, "category": "public.app-category.games",
             "artifactName": "KonohaVivant-${version}.${ext}" },
    "linux": { "target": "AppImage" }
  }
}
